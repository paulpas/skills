{
  "name": "agent-skill-router",
  "version": "1.0.0",
  "private": true,
  "description": "Agent skill routing system for OpenCode",
  "scripts": {
    "lint": "eslint 'agent-skill-routing-system/src/**/*.ts'",
    "lint:fix": "eslint 'agent-skill-routing-system/src/**/*.ts' --fix",
    "format": "prettier --write 'agent-skill-routing-system/src/**/*.{ts,tsx,js,jsx,json,md}'",
    "format:check": "prettier --check 'agent-skill-routing-system/src/**/*.{ts,tsx,js,jsx,json,md}'",
    "test": "cd agent-skill-routing-system && npm run test:unit && npm run test:integration",
    "test:unit": "cd agent-skill-routing-system && jest --testPathPatterns='src/**/*.test.ts'",
    "test:integration": "cd agent-skill-routing-system && jest --testPathPatterns='src/**/*.integration.test.ts'",
    "test:coverage": "cd agent-skill-routing-system && npm run test:coverage",
    "typecheck": "cd agent-skill-routing-system && npm run check",
    "build": "cd agent-skill-routing-system && npm run build",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.4.2",
    "prettier": "^3.3.3",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "build",
          "chore",
          "ci",
          "docs",
          "feat",
          "fix",
          "perf",
          "refactor",
          "revert",
          "style",
          "test",
          "release"
        ]
      ],
      "header-max-length": [
        2,
        "always",
        100
      ]
    }
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/github",
        {
          "assets": [
            "dist/**"
          ],
          "releasedLabels": [
            "Status: Released"
          ]
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
        }
      ]
    ],
    "preset": "conventionalcommits"
  }
}
