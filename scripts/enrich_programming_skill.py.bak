#!/usr/bin/env python3
"""
Enriched Programming Skill Template Generator

This script generates complete SKILL.md files for Programming domain skills
following the exact format specified in SKILL_FORMAT_SPEC.md Section 4.4.

Usage:
    python3 scripts/enrich_programming_skill.py <topic>

Example:
    python3 scripts/enrich_programming_skill.py quicksort
    python3 scripts/enrich_programming_skill.py dijkstra
    python3 scripts/enrich_programming_skill.py binary-search
"""

import sys
import os


def generate_frontmatter(topic: str, topic_display: str) -> str:
    """Generate YAML frontmatter for a Programming skill."""
    return f"""---
name: {topic}
description: Reference guide for {topic_display} algorithm with complexity analysis and Python implementation patterns.
license: MIT
compatibility: opencode
metadata:
  version: "1.0.0"
  domain: programming
  triggers: {topic}, {topic_display}, algorithm, time complexity, space complexity, implementation
  role: reference
  scope: implementation
  output-format: code
  related-skills: coding-test-driven-development, programming-sorting-algorithms, programming-graph-algorithms
---
"""


def generate_h1(topic_display: str) -> str:
    """Generate H1 title."""
    return f"# {topic_display} Algorithm\n"


def generate_role_paragraph(topic: str, topic_display: str) -> str:
    """Generate role/purpose paragraph from model's perspective."""
    return f"""Analyzes and implements {topic_display} algorithm with detailed complexity analysis and practical Python implementation patterns.

{topic_display} is a fundamental algorithm used for {topic_display.lower().replace("algorithm", "").strip() if "algorithm" in topic_display.lower() else "solving specific computational problems"}. This skill provides comprehensive reference material including algorithm steps, complexity analysis, and production-ready code examples.
"""


def generate_tlrd_checklist(topic_display: str) -> str:
    """Generate TL;DR Checklist section."""
    return f"""## TL;DR Checklist

- [ ] Understand the problem domain and input constraints before implementing
- [ ] Choose the correct algorithm variant for your specific use case
- [ ] Verify time complexity meets performance requirements
- [ ] Check space complexity for memory-constrained environments
- [ ] Test with edge cases (empty input, single element, large input)
- [ ] Validate correctness with known test cases before production use
- [ ] Consider numerical stability for floating-point operations
"""


def generate_tlrd_code_generation(topic: str, topic_display: str) -> str:
    """Generate TL;DR for Code Generation section."""
    return f"""## TL;DR for Code Generation

- Use guard clauses - return early on invalid input before doing work
- Return simple types (bool, int, float, list) - avoid returning complex nested dicts unless necessary
- Include comprehensive docstrings with parameter types and return value description
- Use type hints - Python 3.5+ with `:` syntax for all function signatures
- Handle edge cases explicitly (empty input, single element, large values)
- Add assertions for invariants where they improve clarity
- Avoid global state - make functions pure where possible
- Include complexity analysis in docstring or comments
"""


def generate_when_to_use(topic: str, topic_display: str) -> str:
    """Generate When to Use section."""
    return f"""## When to Use

Use this skill when:

- Implementing {topic_display} algorithm for a specific computational problem
- Analyzing time and space complexity requirements for an algorithm
- Needing reference implementation patterns for {topic.lower()}
- Learning or teaching {topic_display} algorithm concepts
- Comparing {topic_display} with alternative algorithms
- Optimizing {topic_display} for specific input characteristics
- Debugging issues with {topic_display} implementation
- Preparing for technical interviews covering {topic_display}
"""


def generate_when_not_to_use(topic: str, topic_display: str) -> str:
    """Generate When NOT to Use section."""
    return f"""## When NOT to Use

Avoid this skill for:

- High-level API usage without understanding underlying algorithm - use existing library functions instead
- Real-time systems with strict timing guarantees without thorough profiling first
- Situations where approximate solutions are acceptable - consider heuristics instead
- Memory-constrained environments without verifying space complexity requirements
- Parallel processing without adapting the algorithm for concurrent execution
- When the problem domain doesn't match the algorithm's intended use case

For similar problems, consider:
- `programming-sorting-algorithms` for sorting operations
- `programming-graph-algorithms` for graph traversal problems
- `coding-test-driven-development` for verifying algorithm correctness
"""


def generate_core_workflow(topic: str, topic_display: str) -> str:
    """Generate Core Workflow section with specific algorithm steps."""
    workflow_map = {
        "quicksort": """1. **Select Pivot** - Choose a pivot element from the array (first, last, middle, or random).
   **Checkpoint:** Random pivot selection prevents worst-case O(n^2) on sorted arrays.

2. **Partition** - Rearrange array so elements less than pivot are left, greater are right.
   **Checkpoint:** Verify pivot ends up in its final sorted position.

3. **Recursive Sort** - Recursively apply the same process to left and right sub-arrays.
   **Checkpoint:** Base case is array of length 0 or 1 (already sorted).

4. **Combine** - Concatenate sorted left partition, pivot, and sorted right partition.
   **Checkpoint:** Verify output is fully sorted and contains all original elements.
""",
        "dijkstra": """1. **Initialize** - Set distance to source as 0, all others as infinity. Add source to priority queue.
   **Checkpoint:** All distances must be initialized before processing.

2. **Extract Minimum** - Remove vertex with smallest distance from priority queue.
   **Checkpoint:** The extracted vertex has its final shortest distance confirmed.

3. **Relax Edges** - For each neighbor, check if path through current vertex is shorter.
   **Checkpoint:** Update distance only if new path is strictly shorter.

4. **Update Priority Queue** - Decrease key for vertices with updated distances.
   **Checkpoint:** Priority queue must reflect current minimum distances.

5. **Repeat** - Continue until priority queue is empty or target reached.
   **Checkpoint:** If target reached, verify no shorter path exists via remaining vertices.
""",
        "binary-search": """1. **Initialize Bounds** - Set low to 0, high to array length minus 1.
   **Checkpoint:** Array must be sorted before searching.

2. **Calculate Midpoint** - Compute mid = low + (high - low) // 2 to avoid overflow.
   **Checkpoint:** Use this formula instead of (low + high) // 2 for large arrays.

3. **Compare Target** - Check if target equals, is less than, or greater than mid element.
   **Checkpoint:** Return mid index if target found.

4. **Narrow Search** - If target < mid, set high = mid - 1; else set low = mid + 1.
   **Checkpoint:** Always move past the mid element to ensure progress.

5. **Termination** - Repeat while low <= high. Return -1 if not found.
   **Checkpoint:** Loop condition must be <= not < to check all elements.
""",
        "merge-sort": """1. **Divide** - Split array into two halves.
   **Checkpoint:** For arrays of length 0 or 1, return as-is (already sorted).

2. **Conquer** - Recursively sort both halves.
   **Checkpoint:** Base case prevents infinite recursion.

3. **Merge** - Combine two sorted sub-arrays into one sorted array.
   **Checkpoint:** Use two pointers to traverse both arrays in linear time.

4. **Return** - Return the merged sorted array.
   **Checkpoint:** Verify all elements from both sub-arrays are included.
""",
        "bubble-sort": """1. **Outer Loop** - Repeat n-1 times where n is array length.
   **Checkpoint:** After i passes, last i elements are in correct position.

2. **Inner Loop** - Compare adjacent elements from start to n-i-1.
   **Checkpoint:** Don't compare already-sorted elements at end.

3. **Swap** - If current element > next element, swap them.
   **Checkpoint:** Track if any swap occurred - if not, array is sorted.

4. **Early Exit** - If no swaps in a pass, terminate early.
   **Checkpoint:** This optimization makes best-case O(n) for already sorted arrays.
""",
    }

    default_workflow = f"""1. **Analyze Problem** - Understand the problem requirements and constraints.
   **Checkpoint:** Identify input/output types and expected behavior.

2. **Design Algorithm** - Choose appropriate {topic_display} approach (divide-and-conquer, greedy, etc.).
   **Checkpoint:** Consider time/space tradeoffs for your specific use case.

3. **Implement Core Logic** - Write the algorithm implementation.
   **Checkpoint:** Test with small examples before scaling.

4. **Optimize** - Apply {topic_display}-specific optimizations.
   **Checkpoint:** Profile before optimizing - don't guess.

5. **Validate** - Test with various inputs including edge cases.
   **Checkpoint:** Verify correctness against known outputs or test cases.
"""

    workflow_content = workflow_map.get(topic, default_workflow)
    return f"""## Core Workflow

{workflow_content}
"""


def generate_implementation_patterns(topic: str, topic_display: str) -> str:
    """Generate Implementation Patterns section with Python code."""

    patterns_map = {
        "quicksort": """### Pattern 1: In-Place QuickSort (BAD vs. GOOD)

```python
# ❌ BAD: Creates new lists - O(n) extra space per recursion level
def bad_quicksort(arr: list) -> list:
    if len(arr) <= 1:
        return arr
    pivot = arr[0]
    left = [x for x in arr if x < pivot]
    middle = [x for x in arr if x == pivot]
    right = [x for x in arr if x > pivot]
    return bad_quicksort(left) + middle + bad_quicksort(right)

# ✅ GOOD: In-place partitioning - O(1) extra space (excluding recursion stack)
def quicksort(
    arr: list,
    low: int = 0,
    high: int = None,
    key: callable = None
) -> None:
    \"\"\"Sort array in-place using quicksort algorithm.
    
    Uses Lomuto partition scheme with random pivot selection
    to avoid worst-case performance on sorted arrays.
    
    Args:
        arr: Array to sort (modified in-place)
        low: Starting index
        high: Ending index (defaults to len(arr) - 1)
        key: Optional key function for custom comparisons
    \"\"\"
    if high is None:
        high = len(arr) - 1
    
    if low < high:
        # Random pivot selection to avoid O(n^2) on sorted arrays
        pivot_idx = _random_partition(arr, low, high, key)
        quicksort(arr, low, pivot_idx - 1, key)
        quicksort(arr, pivot_idx + 1, high, key)


def _partition(
    arr: list,
    low: int,
    high: int,
    key: callable = None
) -> int:
    \"\"\"Partition array around pivot using Lomuto scheme.\"\"\"
    if key is None:
        key = lambda x: x
    
    # Random pivot - swap with last element
    pivot_idx = __import__('random').randint(low, high)
    arr[pivot_idx], arr[high] = arr[high], arr[pivot_idx]
    pivot = arr[high]
    
    i = low - 1
    for j in range(low, high):
        if key(arr[j]) <= key(pivot):
            i += 1
            arr[i], arr[j] = arr[j], arr[i]
    
    arr[i + 1], arr[high] = arr[high], arr[i + 1]
    return i + 1


def _random_partition(
    arr: list,
    low: int,
    high: int,
    key: callable = None
) -> int:
    \"\"\"Helper for random pivot selection.\"\"\"
    import random
    return _partition(arr, low, high, key)
```

### Pattern 2: QuickSelect (Find k-th Element)

```python
def quickselect(
    arr: list,
    k: int,
    low: int = 0,
    high: int = None
) -> int:
    \"\"\"Find the k-th smallest element (0-indexed) using quickselect.
    
    Average time complexity: O(n)
    Worst case: O(n^2) but rare with random pivot
    
    Args:
        arr: Array to search (may be modified)
        k: Index of element to find (0-based)
        low: Starting index
        high: Ending index
    
    Returns:
        The k-th smallest element
    
    Raises:
        ValueError: If k is out of bounds
    \"\"\"
    if high is None:
        high = len(arr) - 1
    
    if not 0 <= k <= high - low + 1:
        raise ValueError(f"k={k} is out of bounds for array of length {high - low + 1}")
    
    while low <= high:
        pivot_idx = _partition(arr, low, high)
        
        if pivot_idx == k:
            return arr[pivot_idx]
        elif pivot_idx > k:
            high = pivot_idx - 1
        else:
            low = pivot_idx + 1
    
    return arr[k]
```

### Pattern 3: Three-Way QuickSort (For Arrays with Duplicates)

```python
def three_way_quicksort(
    arr: list,
    low: int = 0,
    high: int = None
) -> None:
    \"\"\"Three-way partition quicksort for arrays with many duplicates.
    
    Groups equal elements together, improving performance when
    there are many duplicate values.
    \"\"\"
    if high is None:
        high = len(arr) - 1
    
    if low < high:
        lt, gt = _three_way_partition(arr, low, high)
        three_way_quicksort(arr, low, lt - 1)
        three_way_quicksort(arr, gt + 1, high)


def _three_way_partition(
    arr: list,
    low: int,
    high: int
) -> tuple:
    \"\"\"Partition into three parts: < pivot, == pivot, > pivot.\"\"\"
    import random
    pivot_idx = random.randint(low, high)
    arr[pivot_idx], arr[low] = arr[low], arr[pivot_idx]
    pivot = arr[low]
    
    lt = low      # arr[low+1...lt] < pivot
    gt = high + 1 # arr[gt...high] > pivot
    i = low + 1   # arr[lt+1...i-1] == pivot
    
    while i < gt:
        if arr[i] < pivot:
            lt += 1
            arr[lt], arr[i] = arr[i], arr[lt]
            i += 1
        elif arr[i] > pivot:
            gt -= 1
            arr[gt], arr[i] = arr[i], arr[gt]
        else:
            i += 1
    
    arr[low], arr[lt] = arr[lt], arr[low]
    return lt, gt - 1
```
""",
        "dijkstra": """### Pattern 1: Dijkstra's Algorithm with Priority Queue

```python
import heapq
from typing import Dict, List, Tuple, Optional
from collections import defaultdict


def dijkstra(
    graph: Dict[str, List[Tuple[str, float]]],
    source: str,
    target: Optional[str] = None
) -> Dict[str, float]:
    \"\"\"Find shortest paths from source to all vertices using Dijkstra's algorithm.
    
    Args:
        graph: Adjacency list with (neighbor, weight) tuples
        source: Starting vertex
        target: Optional target vertex (early termination if found)
    
    Returns:
        Dictionary mapping each vertex to its shortest distance from source
    
    Raises:
        ValueError: If source not in graph or negative edge weights found
    \"\"\"
    if source not in graph:
        raise ValueError(f"Source vertex '{source}' not in graph")
    
    # Initialize distances
    distances: Dict[str, float] = {vertex: float('inf') for vertex in graph}
    distances[source] = 0.0
    
    # Priority queue: (distance, vertex)
    pq: List[Tuple[float, str]] = [(0.0, source)]
    visited = set()
    
    while pq:
        current_dist, u = heapq.heappop(pq)
        
        # Skip if already visited (we found a shorter path earlier)
        if u in visited:
            continue
        
        visited.add(u)
        
        # Early termination if target reached
        if target is not None and u == target:
            break
        
        # Explore neighbors
        for v, weight in graph.get(u, []):
            if v in visited:
                continue
            
            # Check for negative weights (Dijkstra doesn't handle them)
            if weight < 0:
                raise ValueError(f"Negative edge weight found: {u} -> {v}: {weight}")
            
            new_dist = current_dist + weight
            
            if new_dist < distances[v]:
                distances[v] = new_dist
                heapq.heappush(pq, (new_dist, v))
    
    return distances


def dijkstra_path(
    graph: Dict[str, List[Tuple[str, float]]],
    source: str,
    target: str
) -> Optional[List[str]]:
    \"\"\"Find shortest path from source to target.
    
    Returns:
        List of vertices representing the shortest path, or None if no path exists
    \"\"\"
    distances = dijkstra(graph, source, target)
    
    if target not in distances or distances[target] == float('inf'):
        return None
    
    # Reconstruct path
    path = [target]
    current = target
    
    # Build reverse mapping of predecessors
    predecessors = {}
    visited = set()
    pq = [(0.0, source)]
    
    while pq:
        dist, u = heapq.heappop(pq)
        if u in visited:
            continue
        visited.add(u)
        
        for v, weight in graph.get(u, []):
            if v not in visited:
                new_dist = dist + weight
                if v not in predecessors or new_dist < distances.get(v, float('inf')):
                    predecessors[v] = u
                    heapq.heappush(pq, (new_dist, v))
    
    # Reconstruct from target to source
    current = target
    while current != source:
        if current not in predecessors:
            return None
        current = predecessors[current]
        path.append(current)
    
    return path[::-1]  # Reverse to get source -> target
```

### Pattern 2: Dijkstra's with Distance Matrix (Dense Graphs)

```python
def dijkstra_dense(
    graph: List[List[float]],
    source: int
) -> List[float]:
    \"\"\"Dijkstra's algorithm for dense graphs using array-based priority queue.
    
    More efficient than heap-based for dense graphs (E ~ V^2).
    
    Args:
        graph: Adjacency matrix where graph[i][j] is edge weight (or inf if no edge)
        source: Source vertex index
    
    Returns:
        List of shortest distances from source to each vertex
    \"\"\"
    n = len(graph)
    INF = float('inf')
    distances = [INF] * n
    distances[source] = 0.0
    visited = [False] * n
    
    for _ in range(n):
        # Find minimum distance unvisited vertex
        min_dist = INF
        u = -1
        
        for v in range(n):
            if not visited[v] and distances[v] < min_dist:
                min_dist = distances[v]
                u = v
        
        if u == -1:
            break
        
        visited[u] = True
        
        # Update distances to neighbors
        for v in range(n):
            if not visited[v] and graph[u][v] < INF:
                new_dist = distances[u] + graph[u][v]
                if new_dist < distances[v]:
                    distances[v] = new_dist
    
    return distances
```

### Pattern 3: A* Search (Dijkstra with Heuristic)

```python
import math


def heuristic(a: Tuple[float, float], b: Tuple[float, float]) -> float:
    \"\"\"Euclidean heuristic for 2D grid.\"\"\"
    return math.sqrt((a[0] - b[0]) ** 2 + (a[1] - b[1]) ** 2)


def a_star(
    graph: Dict[Tuple[int, int], List[Tuple[Tuple[int, int], float]]],
    source: Tuple[int, int],
    target: Tuple[int, int]
) -> Optional[List[Tuple[int, int]]]:
    \"\"\"A* search with Euclidean heuristic for grid-based pathfinding.
    
    More efficient than Dijkstra when a good heuristic is available.
    \"\"\"
    open_set = [(heuristic(source, target), 0, source)]  # (f_score, g_score, position)
    came_from = {}
    g_score = {source: 0.0}
    f_score = {source: heuristic(source, target)}
    
    while open_set:
        _, current_g, current = heapq.heappop(open_set)
        
        if current == target:
            # Reconstruct path
            path = [current]
            while current in came_from:
                current = came_from[current]
                path.append(current)
            return path[::-1]
        
        for neighbor, weight in graph.get(current, []):
            tentative_g = current_g + weight
            
            if neighbor not in g_score or tentative_g < g_score[neighbor]:
                came_from[neighbor] = current
                g_score[neighbor] = tentative_g
                f_score[neighbor] = tentative_g + heuristic(neighbor, target)
                heapq.heappush(open_set, (f_score[neighbor], tentative_g, neighbor))
    
    return None
```
""",
        "binary-search": """### Pattern 1: Standard Binary Search

```python
from typing import List, Optional, Any


def binary_search(
    arr: List[Any],
    target: Any,
    key: callable = None
) -> Optional[int]:
    \"\"\"Standard binary search returning index of target.
    
    Args:
        arr: Sorted array to search
        target: Value to find
        key: Optional key function for custom comparisons
    
    Returns:
        Index of target if found, None otherwise
    
    Time: O(log n)
    Space: O(1)
    \"\"\"
    if key is None:
        key = lambda x: x
    
    low, high = 0, len(arr) - 1
    
    while low <= high:
        # Avoid potential overflow: mid = low + (high - low) // 2
        mid = low + (high - low) // 2
        mid_val = key(arr[mid])
        
        if mid_val == target:
            return mid
        elif mid_val < target:
            low = mid + 1
        else:
            high = mid - 1
    
    return None


def binary_search_first(
    arr: List[Any],
    target: Any,
    key: callable = None
) -> Optional[int]:
    \"\"\"Find first occurrence of target in array with duplicates.
    
    Args:
        arr: Sorted array that may contain duplicates
        target: Value to find
        key: Optional key function
    
    Returns:
        Index of first occurrence, None if not found
    \"\"\"
    if key is None:
        key = lambda x: x
    
    low, high = 0, len(arr) - 1
    result = None
    
    while low <= high:
        mid = low + (high - low) // 2
        mid_val = key(arr[mid])
        
        if mid_val == target:
            result = mid
            high = mid - 1  # Continue searching left half
        elif mid_val < target:
            low = mid + 1
        else:
            high = mid - 1
    
    return result


def binary_search_last(
    arr: List[Any],
    target: Any,
    key: callable = None
) -> Optional[int]:
    \"\"\"Find last occurrence of target in array with duplicates.\"\"\"
    if key is None:
        key = lambda x: x
    
    low, high = 0, len(arr) - 1
    result = None
    
    while low <= high:
        mid = low + (high - low) // 2
        mid_val = key(arr[mid])
        
        if mid_val == target:
            result = mid
            low = mid + 1  # Continue searching right half
        elif mid_val < target:
            low = mid + 1
        else:
            high = mid - 1
    
    return result
```

### Pattern 2: Binary Search on Rotated Array

```python
def binary_search_rotated(
    arr: List[int],
    target: int
) -> Optional[int]:
    \"\"\"Binary search on a rotated sorted array.
    
    Handles arrays that were sorted then rotated at some pivot.
    Example: [4, 5, 6, 7, 0, 1, 2] is rotated at index 4.
    
    Args:
        arr: Rotated sorted array (no duplicates)
        target: Value to find
    
    Returns:
        Index of target if found, None otherwise
    
    Time: O(log n)
    \"\"\"
    low, high = 0, len(arr) - 1
    
    while low <= high:
        mid = low + (high - low) // 2
        
        if arr[mid] == target:
            return mid
        
        # Check if left half is sorted
        if arr[low] <= arr[mid]:
            # Left half is sorted
            if arr[low] <= target < arr[mid]:
                high = mid - 1
            else:
                low = mid + 1
        else:
            # Right half is sorted
            if arr[mid] < target <= arr[high]:
                low = mid + 1
            else:
                high = mid - 1
    
    return None


def binary_search_rotated_with_duplicates(
    arr: List[int],
    target: int
) -> Optional[int]:
    \"\"\"Binary search on rotated sorted array with possible duplicates.
    
    When duplicates exist, worst case becomes O(n) when all elements
    are the same except possibly the target.
    \"\"\"
    low, high = 0, len(arr) - 1
    
    while low <= high:
        mid = low + (high - low) // 2
        
        if arr[mid] == target:
            return mid
        
        # Handle duplicates: when arr[low] == arr[mid] == arr[high],
        # we can't determine which half is sorted
        if arr[low] == arr[mid] == arr[high]:
            low += 1
            high -= 1
        elif arr[low] <= arr[mid]:
            # Left half is sorted
            if arr[low] <= target < arr[mid]:
                high = mid - 1
            else:
                low = mid + 1
        else:
            # Right half is sorted
            if arr[mid] < target <= arr[high]:
                low = mid + 1
            else:
                high = mid - 1
    
    return None
```

### Pattern 3: Binary Search for Answer (Decision Problem)

```python
def binary_search_answer(
    left: int,
    right: int,
    predicate: callable
) -> int:
    \"\"\"Binary search to find the minimum value satisfying a predicate.
    
    Used when we can't directly search an array but can test properties
    of numeric answers (e.g., "is this capacity sufficient?").
    
    Args:
        left: Lower bound of search space (satisfies predicate)
        right: Upper bound of search space (may not satisfy)
        predicate: Function that returns True if value is sufficient
    
    Returns:
        Minimum value that satisfies the predicate
    
    Example:
        # Find minimum ship capacity to ship all packages in D days
        capacity = binary_search_answer(max(weights), sum(weights), 
                                         lambda cap: can_ship(weights, D, cap))
    \"\"\"
    while left < right:
        mid = left + (right - left) // 2
        if predicate(mid):
            right = mid  # mid works, try smaller
        else:
            left = mid + 1  # mid doesn't work, try larger
    
    return left


def binary_search_answer_max(
    left: int,
    right: int,
    predicate: callable
) -> int:
    \"\"\"Binary search to find the maximum value satisfying a predicate.\"\"\"
    while left < right:
        mid = left + (right - left + 1) // 2  # Upper mid to avoid infinite loop
        if predicate(mid):
            left = mid  # mid works, try larger
        else:
            right = mid - 1  # mid doesn't work, try smaller
    
    return left
```
