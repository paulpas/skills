        "merge-sort": """### Pattern 1: Bottom-Up Merge Sort (Iterative)

```python
from typing import List, Any


def merge_sort(arr: List[Any], key: callable = None) -> List[Any]:
    \"\"\"Merge sort implementation with in-place merging.
    
    Args:
        arr: Array to sort
        key: Optional key function for custom comparisons
    
    Returns:
        Sorted array (original is not modified)
    
    Time: O(n log n)
    Space: O(n) for temporary arrays
    \"\"\"
    if key is None:
        key = lambda x: x
    
    if len(arr) <= 1:
        return arr[:]
    
    # Create a copy to work with
    result = arr[:]
    temp = [None] * len(result)
    
    # Start with sub-arrays of size 1
    width = 1
    
    while width < len(result):
        # Merge pairs of sub-arrays
        for i in range(0, len(result), 2 * width):
            # Define boundaries of two sub-arrays
            left = i
            mid = min(i + width, len(result))
            right = min(i + 2 * width, len(result))
            
            # Merge the two sub-arrays
            _merge(result, temp, left, mid, right, key)
        
        # Double the sub-array size
        width *= 2
        
        # Copy temp back to result
        result, temp = temp, result
    
    return result


def _merge(
    arr: List[Any],
    temp: List[Any],
    left: int,
    mid: int,
    right: int,
    key: callable
) -> None:
    \"\"\"Merge two sorted sub-arrays arr[left:mid] and arr[mid:right].\"\"\"
    i, j, k = left, mid, left
    
    # Merge while both sub-arrays have elements
    while i < mid and j < right:
        if key(arr[i]) <= key(arr[j]):
            temp[k] = arr[i]
            i += 1
        else:
            temp[k] = arr[j]
            j += 1
        k += 1
    
    # Copy remaining elements from left sub-array
    while i < mid:
        temp[k] = arr[i]
        i += 1
        k += 1
    
    # Copy remaining elements from right sub-array
    while j < right:
        temp[k] = arr[j]
        j += 1
        k += 1


def merge_sort_in_place(
    arr: List[Any],
    low: int = 0,
    high: int = None,
    key: callable = None
) -> None:
    \"\"\"Merge sort that uses the input array for both input and output.
    
    Still requires O(n) auxiliary space but doesn't return a new array.
    Modifies the input array in place.
    \"\"\"
    if high is None:
        high = len(arr) - 1
    
    if key is None:
        key = lambda x: x
    
    if low < high:
        mid = low + (high - low) // 2
        
        # Sort both halves
        merge_sort_in_place(arr, low, mid, key)
        merge_sort_in_place(arr, mid + 1, high, key)
        
        # Merge the sorted halves
        _merge_in_place(arr, low, mid, high, key)


def _merge_in_place(
    arr: List[Any],
    low: int,
    mid: int,
    high: int,
    key: callable
) -> None:
    \"\"\"Merge two sorted sub-arrays in place using temporary storage.\"\"\"
    # Create copies of both sub-arrays
    left = arr[low:mid + 1]
    right = arr[mid + 1:high + 1]
    
    i, j, k = 0, 0, low
    
    # Merge back into original array
    while i < len(left) and j < len(right):
        if key(left[i]) <= key(right[j]):
            arr[k] = left[i]
            i += 1
        else:
            arr[k] = right[j]
            j += 1
        k += 1
    
    # Copy remaining elements
    while i < len(left):
        arr[k] = left[i]
        i += 1
        k += 1
    
    while j < len(right):
        arr[k] = right[j]
        j += 1
        k += 1
```

### Pattern 2: Merge Sort for Linked List

```python
class ListNode:
    def __init__(self, val: int = 0, next: 'ListNode' = None):
        self.val = val
        self.next = next


def merge_sort_linked_list(head: ListNode) -> ListNode:
    \"\"\"Merge sort for linked list (O(1) space complexity).
    
    Unlike arrays, linked lists can be merged in place without
    extra space for temporary arrays.
    
    Args:
        head: Head of the linked list
    
    Returns:
        Head of the sorted linked list
    
    Time: O(n log n)
    Space: O(log n) for recursion stack
    \"\"\"
    if not head or not head.next:
        return head
    
    # Split the list into two halves
    middle = _get_middle(head)
    next_to_middle = middle.next
    middle.next = None
    
    # Sort both halves
    left = merge_sort_linked_list(head)
    right = merge_sort_linked_list(next_to_middle)
    
    # Merge the sorted halves
    return _merge_linked_lists(left, right)


def _get_middle(head: ListNode) -> ListNode:
    \"\"\"Get the middle node of the linked list using slow-fast pointer.\"\"\"
    if not head:
        return head
    
    slow = head
    fast = head.next
    
    while fast and fast.next:
        slow = slow.next
        fast = fast.next.next
    
    return slow


def _merge_linked_lists(
    l1: ListNode,
    l2: ListNode
) -> ListNode:
    \"\"\"Merge two sorted linked lists.\"\"\"
    dummy = ListNode()
    tail = dummy
    
    while l1 and l2:
        if l1.val <= l2.val:
            tail.next = l1
            l1 = l1.next
        else:
            tail.next = l2
            l2 = l2.next
        tail = tail.next
    
    # Attach remaining nodes
    tail.next = l1 if l1 else l2
    
    return dummy.next
```

### Pattern 3: Parallel Merge Sort

```python
from concurrent.futures import ThreadPoolExecutor
import threading


def parallel_merge_sort(
    arr: List[Any],
    max_workers: int = 4,
    min_size: int = 100,
    key: callable = None
) -> List[Any]:
    \"\"\"Merge sort that parallelizes recursive calls for large arrays.
    
    Only parallelizes when sub-arrays are large enough to benefit
    from parallelism (avoids overhead for small arrays).
    
    Args:
        arr: Array to sort
        max_workers: Maximum number of threads
        min_size: Minimum array size to parallelize
        key: Optional key function
    
    Returns:
        Sorted array
    
    Time: O(log n) depth with O(n log n) work
    \"\"\"
    if key is None:
        key = lambda x: x
    
    if len(arr) <= 1:
        return arr[:]
    
    # Use thread pool for parallel execution
    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        return _parallel_merge_sort_impl(arr, executor, min_size, key)


def _parallel_merge_sort_impl(
    arr: List[Any],
    executor: ThreadPoolExecutor,
    min_size: int,
    key: callable
) -> List[Any]:
    \"\"\"Implementation that uses executor for parallel calls.\"\"\"
    n = len(arr)
    
    # Base case: use regular merge sort for small arrays
    if n <= min_size:
        return merge_sort(arr, key)
    
    mid = n // 2
    
    # Submit left and right halves to thread pool
    left_future = executor.submit(
        _parallel_merge_sort_impl,
        arr[:mid],
        executor,
        min_size,
        key
    )
    right_future = executor.submit(
        _parallel_merge_sort_impl,
        arr[mid:],
        executor,
        min_size,
        key
    )
    
    # Wait for both to complete and merge
    left = left_future.result()
    right = right_future.result()
    
    return _merge(left, right, key)


def _merge(left: List[Any], right: List[Any], key: callable) -> List[Any]:
    \"\"\"Merge two sorted arrays.\"\"\"
    result = []
    i = j = 0
    
    while i < len(left) and j < len(right):
        if key(left[i]) <= key(right[j]):
            result.append(left[i])
            i += 1
        else:
            result.append(right[j])
            j += 1
    
    result.extend(left[i:])
    result.extend(right[j:])
    
    return result
```
