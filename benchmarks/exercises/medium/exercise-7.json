{
  "name": "Multi-Repo Management",
  "tier": "medium",
  "description": "Managing multiple repositories with consistent versioning, branching, and quality",
  "task": "Manage multiple repositories with consistent versioning, branching strategies, quality standards, and architectural patterns. How do we keep everything synchronized and avoid drift?",
  "required_skills": [
    "coding-git-advanced",
    "coding-semver-automation",
    "coding-git-branching-strategies",
    "coding-code-quality-policies",
    "coding-architectural-patterns"
  ],
  "complexity_factors": {
    "query_length": "long",
    "context_complexity": 7,
    "expected_routing_paths": 3,
    "skill_interdependencies": "high"
  },
  "coding_challenge": {
    "description": "Write a repo sync manager for version consistency across multiple repositories. Accept repo list and version constraints. Return sync status and conflicts detected.",
    "language": "python",
    "difficulty": "medium",
    "success_criteria": {
      "must_compile": true,
      "must_run": true,
      "test_cases": [
        {
          "input": [
            [
              "repo-a@1.0",
              "repo-b@1.0"
            ]
          ],
          "expected_output": "synced"
        },
        {
          "input": [
            [
              "repo-a@1.0",
              "repo-b@2.0"
            ]
          ],
          "expected_output": "conflict_detected"
        },
        {
          "input": [
            [
              "repo-a@2.5",
              "repo-b@2.5",
              "repo-c@2.5"
            ]
          ],
          "expected_output": "synced"
        }
      ],
      "code_quality_checks": [
        "no_dead_code",
        "under_10_cyclomatic",
        "proper_error_handling"
      ]
    }
  }
}