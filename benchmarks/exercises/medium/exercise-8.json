{
  "name": "Monorepo Setup",
  "tier": "medium",
  "description": "Monorepo design with shared architecture, versioning, quality, and workflows",
  "task": "Design a monorepo structure that supports multiple services with shared architectural patterns, quality standards, semantic versioning per package, and coordinated git workflows.",
  "required_skills": [
    "coding-architectural-patterns",
    "coding-code-quality-policies",
    "coding-git-advanced",
    "coding-semver-automation",
    "coding-git-branching-strategies"
  ],
  "complexity_factors": {
    "query_length": "long",
    "context_complexity": 7,
    "expected_routing_paths": 3,
    "skill_interdependencies": "high"
  },
  "coding_challenge": {
    "description": "Write a monorepo workspace manager handling shared dependencies, build ordering, and versioning. Accept workspace structure and resolve dependencies. Return build order.",
    "language": "python",
    "difficulty": "medium",
    "success_criteria": {
      "must_compile": true,
      "must_run": true,
      "test_cases": [
        {
          "input": [
            [
              "pkg-a",
              "pkg-b->pkg-a"
            ]
          ],
          "expected_output": [
            "pkg-a",
            "pkg-b"
          ]
        },
        {
          "input": [
            [
              "pkg-a->pkg-b",
              "pkg-b->pkg-a"
            ]
          ],
          "expected_output": "circular_dependency"
        },
        {
          "input": [
            [
              "api",
              "web->api",
              "cli->api"
            ]
          ],
          "expected_output": [
            "api",
            "web",
            "cli"
          ]
        }
      ],
      "code_quality_checks": [
        "no_dead_code",
        "under_10_cyclomatic",
        "proper_error_handling"
      ]
    }
  }
}