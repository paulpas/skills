{
  "name": "Release Pipeline",
  "tier": "medium",
  "description": "Complete release process with versioning, quality gates, team workflows",
  "task": "Build a complete release process: semantic versioning of releases, quality gates to pass, team branching workflow, and automated steps. How do we ensure consistency across releases?",
  "required_skills": [
    "coding-semver-automation",
    "coding-code-quality-policies",
    "coding-git-advanced",
    "coding-git-branching-strategies"
  ],
  "complexity_factors": {
    "query_length": "long",
    "context_complexity": 6,
    "expected_routing_paths": 2,
    "skill_interdependencies": "high"
  },
  "coding_challenge": {
    "description": "Write a release orchestrator that coordinates version bump, build, test, and deploy stages. Accept release config and return execution plan with status.",
    "language": "python",
    "difficulty": "medium",
    "success_criteria": {
      "must_compile": true,
      "must_run": true,
      "test_cases": [
        {
          "input": [
            [
              "1.0.0",
              "minor"
            ]
          ],
          "expected_output": "1.1.0_released"
        },
        {
          "input": [
            [
              "2.0.0",
              "major"
            ]
          ],
          "expected_output": "3.0.0_released"
        },
        {
          "input": [
            [
              "1.5.0",
              "patch"
            ]
          ],
          "expected_output": "1.5.1_released"
        }
      ],
      "code_quality_checks": [
        "no_dead_code",
        "under_10_cyclomatic",
        "proper_error_handling"
      ]
    }
  }
}