{
  "name": "Security Patch Process",
  "tier": "medium",
  "description": "Security-first release process with CVE scanning and versioning",
  "task": "Establish a process to find security vulnerabilities in our dependencies, review them, and release patches. How do we version a security hotfix? What's our rollout strategy?",
  "required_skills": [
    "coding-security-review",
    "coding-cve-dependency-management",
    "coding-semver-automation"
  ],
  "complexity_factors": {
    "query_length": "medium",
    "context_complexity": 5,
    "expected_routing_paths": 2,
    "skill_interdependencies": "high"
  },
  "coding_challenge": {
    "description": "Write a patch manager that validates version constraints. Accept vulnerable package versions and allowed version ranges. Return applicable patches or empty list.",
    "language": "python",
    "difficulty": "medium",
    "success_criteria": {
      "must_compile": true,
      "must_run": true,
      "test_cases": [
        {
          "input": [
            [
              "lodash@3.0.0"
            ],
            ">=4.0.0"
          ],
          "expected_output": [
            "lodash@4.17.21"
          ]
        },
        {
          "input": [
            [
              "safe@2.0.0"
            ],
            ">=1.0.0"
          ],
          "expected_output": []
        },
        {
          "input": [
            [
              "old@1.0.0",
              "dep@2.0.0"
            ]
          ],
          "expected_output": [
            "old@2.0.0",
            "dep@3.0.0"
          ]
        }
      ],
      "code_quality_checks": [
        "no_dead_code",
        "under_10_cyclomatic",
        "proper_error_handling"
      ]
    }
  }
}