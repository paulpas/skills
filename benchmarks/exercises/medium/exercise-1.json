{
  "name": "Full CI/CD Workflow",
  "tier": "medium",
  "description": "CI/CD pipeline design requiring versioning, branching, and quality checks",
  "task": "Build a CI/CD pipeline that automatically bumps semantic versions, enforces code quality gates, and uses a proper branching strategy. All changes should be tested before merge.",
  "required_skills": [
    "coding-git-branching-strategies",
    "coding-semver-automation",
    "coding-code-quality-policies"
  ],
  "complexity_factors": {
    "query_length": "medium",
    "context_complexity": 5,
    "expected_routing_paths": 2,
    "skill_interdependencies": "high"
  },
  "coding_challenge": {
    "description": "Write a CI/CD pipeline configuration builder class. Accept build stages, tests, and deployment config. Generate YAML and validate structure. Return config dict.",
    "language": "python",
    "difficulty": "medium",
    "success_criteria": {
      "must_compile": true,
      "must_run": true,
      "test_cases": [
        {
          "input": [
            [
              "build",
              "test",
              "deploy"
            ]
          ],
          "expected_output": "valid_config"
        },
        {
          "input": [
            [
              "build",
              "invalid_stage"
            ]
          ],
          "expected_output": "invalid_config"
        },
        {
          "input": [
            [
              "test",
              "deploy",
              "notify"
            ]
          ],
          "expected_output": "valid_config"
        }
      ],
      "code_quality_checks": [
        "no_dead_code",
        "under_10_cyclomatic",
        "proper_error_handling"
      ]
    }
  }
}