    "difficulty": "medium",
    "success_criteria": {
      "must_compile": true,
      "must_run": true,
      "test_cases": [
        {
          "input": [
            [
              "feature",
              "team-a"
            ],
            [
              "team-b"
            ]
          ],
          "expected_output": "routed"
        },
        {
          "input": [
            [
              "bug",
              "team-a"
            ]
          ],
          "expected_output": "assigned"
        },
        {
          "input": [
            [
              "security",
              "team-c"
            ],
            [
              "team-a",
              "team-b"
            ]
          ],
          "expected_output": "escalated"
        }
      ],
      "code_quality_checks": [
        "no_dead_code",
        "under_10_cyclomatic",
        "proper_error_handling"
      ]
    }
