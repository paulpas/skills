{
  "name": "Security-Focused Release",
  "tier": "medium",
  "description": "Release pipeline with security scanning, code review, and versioning",
  "task": "Create a secure release pipeline: scan dependencies for CVEs, review code for security issues, version patches appropriately, and establish quality gates. What's our process for security incidents?",
  "required_skills": [
    "coding-security-review",
    "coding-cve-dependency-management",
    "coding-semver-automation",
    "coding-code-quality-policies"
  ],
  "complexity_factors": {
    "query_length": "long",
    "context_complexity": 6,
    "expected_routing_paths": 2,
    "skill_interdependencies": "high"
  },
  "coding_challenge": {
    "description": "Write a security gate checker that validates CVEs, licenses, and dependency versions before release. Return pass/fail with details on violations found.",
    "language": "python",
    "difficulty": "medium",
    "success_criteria": {
      "must_compile": true,
      "must_run": true,
      "test_cases": [
        {
          "input": [
            [
              "safe_deps",
              "approved_licenses"
            ]
          ],
          "expected_output": "pass"
        },
        {
          "input": [
            [
              "vulnerable_deps"
            ]
          ],
          "expected_output": "fail_cve"
        },
        {
          "input": [
            [
              "unknown_licenses"
            ]
          ],
          "expected_output": "fail_license"
        }
      ],
      "code_quality_checks": [
        "no_dead_code",
        "under_10_cyclomatic",
        "proper_error_handling"
      ]
    }
  }
}